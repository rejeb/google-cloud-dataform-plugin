<idea-plugin>
    <id>io.github.rejeb.gcp-dataform-plugin</id>

    <name>Google Cloud Dataform</name>

    <vendor url="https://github.com/rejeb/google-cloud-dataform-plugin">rbenrejeb</vendor>

    <description><![CDATA[
        Plugin to develop using google cloud dataform.<br>
        <em>Google Cloud, Dataform, BigQuery, SQLX, Javascript</em>
    ]]></description>


    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>JavaScript</depends>
    <depends>NodeJS</depends>
    <depends>com.intellij.modules.sql</depends>
    <depends>com.intellij.database</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="JavaScript.JsonSchema">
        <ProviderFactory
                implementation="io.github.rejeb.dataform.language.completion.DataformJsonSchemaProviderFactory"/>
    </extensions>
    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceInterface="io.github.rejeb.dataform.setup.DataformInterpreterManager"
                        serviceImplementation="io.github.rejeb.dataform.setup.DataformInterpreterManagerImpl"
                        testServiceImplementation="io.github.rejeb.dataform.language.setup.DataformInterpreterManagerTestImpl"
        />
        <projectService serviceInterface="io.github.rejeb.dataform.language.schema.json.ProtoParser"
                        serviceImplementation="io.github.rejeb.dataform.language.schema.json.ProtoParserImpl"
        />
        <projectService serviceInterface="io.github.rejeb.dataform.language.schema.json.DataformJsonSchemaGenerator"
                        serviceImplementation="io.github.rejeb.dataform.language.schema.json.DataformJsonSchemaGeneratorImpl"
        />
        <projectService serviceInterface="io.github.rejeb.dataform.language.schema.dts.DataformDtsGenerator"
                        serviceImplementation="io.github.rejeb.dataform.language.schema.dts.DataformDtsGeneratorImpl"
        />
        <projectService serviceInterface="io.github.rejeb.dataform.language.schema.sql.BigQueryDryRunSchemaExtractor"
                        serviceImplementation="io.github.rejeb.dataform.language.schema.sql.BigQueryDryRunSchemaExtractorImpl"
        />
        <projectService serviceInterface="io.github.rejeb.dataform.language.schema.sql.DataformTableSchemaService"
                        serviceImplementation="io.github.rejeb.dataform.language.schema.sql.DataformTableSchemaServiceImpl"
        />
        <projectService serviceInterface="io.github.rejeb.dataform.language.service.DataformCompilationService"
                        serviceImplementation="io.github.rejeb.dataform.language.service.DataformCompilationServiceImpl"
        />
        <projectService serviceInterface="io.github.rejeb.dataform.language.service.DataformCoreIndexService"
                        serviceImplementation="io.github.rejeb.dataform.language.service.DataformCoreIndexServiceImpl"
        />
        <projectService serviceInterface="io.github.rejeb.dataform.language.service.WorkflowSettingsService"
                        serviceImplementation="io.github.rejeb.dataform.language.service.WorkflowSettingsServiceImpl"
        />
        <projectService
                serviceInterface="io.github.rejeb.dataform.language.gcp.settings.GcpRepositorySettings"
                serviceImplementation="io.github.rejeb.dataform.language.gcp.settings.GcpRepositorySettingsImpl"/>

        <projectService
                serviceInterface="io.github.rejeb.dataform.language.gcp.service.DataformGcpService"
                serviceImplementation="io.github.rejeb.dataform.language.gcp.service.DataformGcpServiceImpl"/>

        <toolWindow
                id="Dataform GCP"
                anchor="right"
                factoryClass="io.github.rejeb.dataform.language.gcp.toolwindow.DataformGcpToolWindowFactory"
                icon="/icons/dataform-panel.png"/>
        <sql.resolveExtension
                implementation="io.github.rejeb.dataform.language.schema.sql.DataformSqlResolveExtension"/>
        <projectImportProvider
                implementation="io.github.rejeb.dataform.projectWizard.DataformProjectImportProvider"/>
        <daemon.highlightInfoFilter
                implementation="io.github.rejeb.dataform.language.highlight.SqlxHighlightInfoFilter"/>
        <facetType implementation="io.github.rejeb.dataform.projectWizard.DataformFacetType"/>
        <framework.detector implementation="io.github.rejeb.dataform.projectWizard.DataformFrameworkDetector"/>
        <projectStructureDetector
                implementation="io.github.rejeb.dataform.projectWizard.DataformProjectStructureDetector"/>

        <compiler.task execute="BEFORE"
                       implementation="io.github.rejeb.dataform.language.compilation.DataformCompileBeforeTask"/>
        <moduleBuilder builderClass="io.github.rejeb.dataform.projectWizard.DataformModuleBuilder"/>

        <postStartupActivity
                order="first"
                implementation="io.github.rejeb.dataform.setup.DataformInstaller"/>
        <backgroundPostStartupActivity
                implementation="io.github.rejeb.dataform.language.startup.DataformProjectStartup"/>
        <fileEditorProvider implementation="io.github.rejeb.dataform.language.fileEditor.SqlxSplitEditorProvider"/>
        <fileType name="SQLX"
                  implementationClass="io.github.rejeb.dataform.language.SqlxFileType"
                  fieldName="INSTANCE"
                  language="SQLX"
                  extensions="sqlx"/>

        <fileType.fileViewProviderFactory
                filetype="SQLX"
                implementationClass="io.github.rejeb.dataform.language.SqlxFileViewProviderFactory"/>

        <lang.parserDefinition
                language="SQLX"
                implementationClass="io.github.rejeb.dataform.language.parser.SqlxParserDefinition"/>

        <multiHostInjector implementation="io.github.rejeb.dataform.language.injection.SqlxSqlInjector"/>

        <multiHostInjector
                implementation="io.github.rejeb.dataform.language.injection.SqlxConfigInjector"/>

        <multiHostInjector
                implementation="io.github.rejeb.dataform.language.injection.SqlxJsInjector"/>

        <multiHostInjector
                implementation="io.github.rejeb.dataform.language.injection.SqlxTemplateInjector"/>

        <multiHostInjector
                implementation="io.github.rejeb.dataform.language.injection.SqlxOperationsInjector"/>

        <completion.contributor
                language="JavaScript"
                implementationClass="io.github.rejeb.dataform.language.completion.DataformJsSymbolCompletionContributor"/>

        <completion.contributor
                language="JavaScript"
                implementationClass="io.github.rejeb.dataform.language.completion.DataformWorkflowSettingsCompletionContributor"/>

        <completion.contributor
                language="SQL"
                implementationClass="io.github.rejeb.dataform.language.completion.SqlxKeywordCompletionContributor"/>

        <psi.referenceContributor
                language="JavaScript"
                implementation="io.github.rejeb.dataform.language.reference.DataformBuiltinFunctionReferenceContributor"/>

        <psi.referenceContributor
                language="JavaScript"
                implementation="io.github.rejeb.dataform.language.reference.DataformIncludeNameOnlyReferenceContributor"/>

        <psi.referenceContributor
                language="JavaScript"
                implementation="io.github.rejeb.dataform.language.reference.DataformRefReferenceContributor"/>

        <psi.referenceContributor
                language="JavaScript"
                implementation="io.github.rejeb.dataform.language.reference.DataformWorkflowSettingsReferenceContributor"/>

        <psi.referenceContributor
                language="JavaScript"
                implementation="io.github.rejeb.dataform.language.reference.DataformJsReferenceContributor"/>

        <lang.elementManipulator
                forClass="io.github.rejeb.dataform.language.psi.SqlxSqlBlock"
                implementationClass="io.github.rejeb.dataform.language.psi.SqlxSqlBlockManipulator"/>
        <lang.elementManipulator
                forClass="io.github.rejeb.dataform.language.psi.SqlxConfigBlock"
                implementationClass="io.github.rejeb.dataform.language.psi.SqlxConfigBlockManipulator"/>

        <lang.elementManipulator
                forClass="io.github.rejeb.dataform.language.psi.SqlxJsLiteralExpression"
                implementationClass="io.github.rejeb.dataform.language.psi.SqlxJsLiteralExpressionManipulator"/>

        <notificationGroup id="Dataform.Notifications"
                           displayType="BALLOON"
                           isLogByDefault="true"
        />

    </extensions>
</idea-plugin>